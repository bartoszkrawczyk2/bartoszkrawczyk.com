---
import { twMerge } from 'tailwind-merge';
import Icon from './icon/Icon.astro';
import type { ResumeEntry } from '@/data/resume';

interface Props {
  class?: string;
  resume: ResumeEntry;
}

const { class: className, resume, ...props } = Astro.props;
const dateRange = [resume.from, resume.to].filter((v) => v).join(' - ');
---

<li
  class={twMerge(
    'relative mb-4 pl-8 md:pl-60 before:absolute before:bg-blue-600 before:w-0.5 before:top-6 before:left-2 md:before:left-[205px] before:-bottom-12 last:before:h-0 after:absolute after:bg-blue-600 after:rounded-full after:w-4 after:h-4 after:left-[1px] md:after:left-[198px] after:top-6 after:shadow-md before:shadow',
    className,
  )}
  {...props}
>
  {
    (resume.from || resume.to) && (
      <div class="md:absolute left-0 pt-5 text-slate-600 md:text-right w-60 md:pr-16 pb-4 md:pb-0">{dateRange}</div>
    )
  }
  <div class="p-6 bg-slate-100 rounded animate-timeline-item">
    {
      resume.company && (
        <h3 class="text-xl sm:text-2xl md:text-3xl font-extrabold tracking-tighter mb-0.5">{resume.company}</h3>
      )
    }
    {
      resume.position && (
        <h4 class="text-blue-600 text-lg sm:text-xl md:text-2xl font-extrabold tracking-tighter mb-4">
          {resume.position}
        </h4>
      )
    }
    <div class="border-b-slate-300 border-b pb-4">
      <slot />
    </div>
    {
      resume.responsibilites && (
        <div class="mt-4">
          <strong class="text-slate-600 font-extrabold tracking-tighter">Responsibilities: </strong>
          <p class="mt-1">{resume.responsibilites}</p>
        </div>
      )
    }
    {
      resume.icons && resume.icons.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {resume.icons.map((icon) => (
            <span title={icon}>
              <Icon icon={icon} class="h-6 md:h-8" dimmed />
            </span>
          ))}
        </div>
      )
    }
  </div>
</li>
