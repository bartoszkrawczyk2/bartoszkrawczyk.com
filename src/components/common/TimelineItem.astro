---
import { twMerge } from 'tailwind-merge';
import Icon from './icon/Icon.astro';
import type { CollectionEntry } from 'astro:content';
import { dateFmt } from '@/utils/intl';

interface Props {
  class?: string;
  entry: CollectionEntry<'resume'>;
}

const { class: className, entry, ...props } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();
const dateRange = [dateFmt(data.from), dateFmt(data.to)].join(' - ');
---

<li
  class={twMerge(
    'relative mb-4 pl-8 md:pl-60 before:absolute before:bg-blue-600 before:w-0.5 before:top-6 before:left-2 md:before:left-[205px] before:-bottom-12 last:before:h-0 after:absolute after:bg-blue-600 after:rounded-full after:w-4 after:h-4 after:left-[1px] md:after:left-[198px] after:top-6 after:shadow-md before:shadow',
    className,
  )}
  {...props}
>
  <div class="md:absolute left-0 pt-5 text-slate-600 md:text-right w-60 md:pr-16 pb-4 md:pb-0">{dateRange}</div>
  <div class="p-6 bg-slate-100 rounded animate-timeline-item">
    <h3 class="text-xl sm:text-2xl md:text-3xl font-extrabold tracking-tighter mb-0.5">{data.company}</h3>
    <h4 class="text-blue-600 text-lg sm:text-xl md:text-2xl font-extrabold tracking-tighter mb-4">
      {data.position}
    </h4>
    <div class="resume-content">
      <Content />
    </div>
    {
      data.icons && data.icons.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {data.icons.map((icon) => (
            <span title={icon}>
              <Icon icon={icon} class="h-6 md:h-8" dimmed />
            </span>
          ))}
        </div>
      )
    }
  </div>
</li>

<style is:global>
  .resume-content > p:first-child {
    @apply border-b border-b-slate-300 pb-4;
  }
  .resume-content > h2 {
    @apply text-slate-600 font-extrabold tracking-tighter text-base mt-4 mb-1;
  }
  .resume-content > h2 + p {
    @apply mt-0;
  }
</style>
