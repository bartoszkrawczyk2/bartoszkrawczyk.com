---
import '@/styles/globals.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Software developer focusing on front-end. Working with React, Next.js, Node.js, Redux, image processing, WebGL, realtime and scalable apps.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="antialiased bg-slate-100 text-gray-800 tracking-tight font-sans">
    <slot />
  </body>
</html>
